# ==============================================
# ResolveAI Backend — Environment Configuration
# ==============================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.

# --- Security ---
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=changeme-generate-a-real-secret-key

# --- Database ---
# PostgreSQL (default):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resolve_ai
# SQLite (lightweight local alternative):
# DATABASE_URL=sqlite:///./resolve_ai.db

# --- OpenAI ---
OPENAI_API_KEY=

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Qdrant Vector Database ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=resolve_ai_memories
